{% extends 'base.html.twig' %}

{% block robots %}index, follow{% endblock %}
{% block title %}Nos interventions (Avant/Après){% endblock %}
{% block description %}Découvrez nos interventions en photos (avant/après) dans tout le Rhône-Alpes : débarras, nettoyage et syndrome de Diogène.{% endblock %}
{% block url %}{{ path('app_service_intervention') }}{% endblock %}

{% block ogTitle %}ESP - Nos interventions (Avant/Après){% endblock %}
{% block ogUrl %}https://esp-rhone-alpes.fr/nos-interventions{% endblock %}
{% block ogImage %}{{ asset('medias/site/banniere.webp') }}{% endblock %}
{% block ogImageAlt %}ESP Débarras et Nettoyage{% endblock %}
{% block ogDescription %}Découvrez nos interventions en photos (avant/après) dans tout le Rhône-Alpes : débarras, nettoyage et syndrome de Diogène.{% endblock %}

{% block body %}
    <section class="bg-white py-16 sm:py-24 mx-auto max-w-7xl px-6 lg:px-8 ">
        <div class="mx-auto max-w-3xl text-center px-6 lg:px-8">
            <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Nos interventions</h1>
            <p class="mt-8 text-pretty text-lg text-gray-700">Nous intervenons +150 fois par ans 7j/j pour des <u class="underline underline-offset-4 decoration-dotted">nettoyages</u>,
                <u class="underline underline-offset-4 decoration-dotted">débarras</u> et <u class="underline underline-offset-4 decoration-dotted">syndrome de Diogène</u> extrême partout dans le Rhône-Alpes.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-6 mt-10 sm:mt-16">
            <div class="max-w-lg sm:w-full mx-auto bg-gray-50 rounded-2xl">
                <img src="{{ asset('medias/site/esp-intervention-1-diogene.webp') }}" class="w-full rounded-2xl" alt="Nettoyage et débarras syndrome de Diogène à Lyon en Rhône-Alpes">
                <div class="px-3 py-6">
                    <p class="text-center font-semibold text-gray-700">Intervention syndrome de Diogène à Lyon</p>
                </div>
            </div>
            <div class="max-w-lg sm:w-full mx-auto bg-gray-50 rounded-2xl">
                <img src="{{ asset('medias/site/esp-intervention-2-debarras-nettoyage.webp') }}" class="w-full rounded-2xl" alt="Intervention de débarras et nettoyage Diogène à Lyon, Rhône-Alpes">
                <div class="px-3 py-6">
                    <p class="text-center font-semibold text-gray-700">Intervention syndrome de Diogène à Lyon</p>
                </div>
            </div>
            <div class="max-w-lg sm:w-full mx-auto bg-gray-50 rounded-2xl">
                <img src="{{ asset('medias/site/esp-intervention-3-nettoyage.webp') }}" class="w-full rounded-2xl" alt="Dépollution, débarras et nettoyage Diogène à Grenoble, Rhône-Alpes">
                <div class="px-3 py-6">
                    <p class="text-center font-semibold text-gray-700">Intervention syndrome de Diogène à Grenoble</p>
                </div>
            </div>
            <div class="max-w-lg sm:w-full mx-auto bg-gray-50 rounded-2xl">
                <img src="{{ asset('medias/site/esp-intervention-4-debarras.webp') }}" class="w-full rounded-2xl" alt="Intervention de débarras et nettoyage syndrome de Diogène à Chambéry en Rhône-Alpes">
                <div class="px-3 py-6">
                    <p class="text-center font-semibold text-gray-700">Intervention syndrome de Diogène à Chambéry</p>
                </div>
            </div>
            <div class="max-w-lg sm:w-full mx-auto bg-gray-50 rounded-2xl">
                <img src="{{ asset('medias/site/esp-intervention-5-debarras.webp') }}" class="w-full rounded-2xl" alt="Nettoyage et débarras en cas de syndrome de Diogène à Valence, Rhône-Alpes">
                <div class="px-3 py-6">
                    <p class="text-center font-semibold text-gray-700">Intervention syndrome de Diogène à Valence</p>
                </div>
            </div>
            <div class="max-w-lg sm:w-full mx-auto bg-gray-50 rounded-2xl">
                <img src="{{ asset('medias/site/esp-intervention-6-diogene.webp') }}" class="w-full rounded-2xl" alt="Intervention rapide de débarras et nettoyage Diogène à Villeurbanne, Rhône-Alpes">
                <div class="px-3 py-6">
                    <p class="text-center font-semibold text-gray-700">Intervention syndrome de Diogène à Villeurbanne</p>
                </div>
            </div>
            <div class="max-w-lg sm:w-full mx-auto bg-gray-50 rounded-2xl">
                <img src="{{ asset('medias/site/esp-intervention-7-diogene-mettoyage.webp') }}" class="w-full rounded-2xl" alt="Dépollution, nettoyage et débarras syndrome de Diogène à Saint-Étienne en Rhône-Alpes">
                <div class="px-3 py-6">
                    <p class="text-center font-semibold text-gray-700">Intervention syndrome de Diogène à Saint-Étienne</p>
                </div>
            </div>
            <div class="max-w-lg sm:w-full mx-auto bg-gray-50 rounded-2xl">
                <img src="{{ asset('medias/site/esp-intervention-8-nettoyage.webp') }}" class="w-full rounded-2xl" alt="Service de nettoyage et débarras syndrome de Diogène à Grenoble, Rhône-Alpes">
                <div class="px-3 py-6">
                    <p class="text-center font-semibold text-gray-700">Intervention syndrome de Diogène à Grenoble</p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
