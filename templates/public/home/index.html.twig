{% extends 'base.html.twig' %}

{% block title %}Entreprise de Débarras et Nettoyage express en Rhône-Alpes{% endblock %}
{% block description %}Entreprise experte en débarras, nettoyage et syndrome de Diogène en Rhône-Alpes. Intervention 7j/7 pour particuliers et professionnels, devis sous 24h.{% endblock %}
{% block url %}{{ path('app_home') }}{% endblock %}

{% block schema %}
    <script type="application/ld+json" nonce="{{ csp_nonce() }}">
    {
        "@context": "https://schema.org",
        "@type": "Service",
        "serviceType": "Débarras, nettoyage et intervention syndrome de Diogène",
        "provider": { "@id": "https://esp-rhone-alpes.fr/#organization" },
        "areaServed": { "@type": "AdministrativeArea", "name": "Rhône-Alpes" },
        "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Prestations ESP",
            "itemListElement": [
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Débarras maison, appartement, locaux professionnels" } },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Nettoyage post-chantier, post-incendie, post-décès" } },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Intervention syndrome de Diogène et syllogomanie" } }
            ]
        }
    }
    </script>
{% endblock %}

