{% extends 'base.html.twig' %}

{% block title %}Blog - Conseils débarras, nettoyage et Diogène{% endblock %}
{% block description %}Découvrez nos articles sur le débarras, le nettoyage et la gestion du syndrome de Diogène. Conseils, astuces et retours d’expérience pour vous guider.{% endblock %}
{% block url %}{{ path('app_blog') }}{% endblock %}

{% block ogType %}website{% endblock %}

{% block schema %}
    <script type="application/ld+json" nonce="{{ csp_nonce() }}">
    {
        "@context": "https://schema.org",
        "@type": "Blog",
        "name": "Blog ESP Débarras et Nettoyage",
        "url": "https://esp-rhone-alpes.fr{{ path('app_blog') }}",
        "publisher": { "@id": "https://esp-rhone-alpes.fr/#organization" }
    }
    </script>
{% endblock %}

{% block body %}
    <div class="bg-white px-6 py-16 sm:py-24">
        <div class="mx-auto max-w-7xl lg:px-8">
            <section class="mx-auto max-w-2xl lg:mx-0">
                <h1 class="mt-2 text-5xl font-bold tracking-tight text-gray-900 sm:text-6xl">Le blog</h1>
                <p class="mt-8 text-pretty text-lg text-gray-700">Découvrez nos conseils, astuces et retours d’expérience sur le débarras, le nettoyage et la gestion de situations complexes.</p>
            </section>
            <section class="mx-auto mt-16 grid max-w-2xl grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-12 lg:mx-0 lg:max-w-none lg:grid-cols-3">
                {% for post in posts %}
                    <article class="flex flex-col items-start justify-between">
                        <div class="relative w-full">
                            <img src="{{ asset('medias/blog/'~post.mainPhoto) }}" alt="{{ post.altMainPhoto }}" loading="lazy" width="600" height="400" class="aspect-video w-full rounded-2xl bg-gray-100 object-cover sm:aspect-[2/1] lg:aspect-[3/2]">
                            <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-gray-900/10"></div>
                        </div>
                        <div class="max-w-xl">
                            <div class="mt-8 flex items-center gap-x-4 text-xs">
                                <time datetime="{{ post.createdAt | date('Y-m-d') }}" class="text-gray-500">{{ post.createdAt | date('d F Y') | format_date(locale='fr') }}</time>
                                <span class="relative z-10 rounded-full bg-gray-50 px-3 py-1.5 font-medium text-gray-600 cap">{{ post.category.name }}</span>
                            </div>
                            <div class="group relative">
                                <h2 class="mt-3 text-lg/6 font-semibold text-gray-900 group-hover:text-gray-600 cap">
                                    <a href="{{ path('app_blog_post', {'slug': post.slug }) }}">
                                        <span class="absolute inset-0"></span>
                                        {{ post.title }}
                                    </a>
                                </h2>
                                <p class="mt-5 line-clamp-3 text-sm/6 text-gray-600">
                                    {{ post.summary }}
                                </p>
                            </div>
                            <div class="relative mt-8 flex items-center gap-x-4">
                                <img src="{{ asset('medias/site/esp.webp') }}" alt="Logo ESP Débarras et Nettoyage" loading="lazy" width="40" height="40" class="size-10 rounded-full bg-gray-100 border-2 border-primary">
                                <div class="text-sm/6">
                                    <h3 class="font-semibold text-gray-900">
                                        <span class="absolute inset-0"></span>
                                        L'équipe d'ESP
                                    </h3>
                                    <p class="text-gray-600 text-xs">Expert Débarras & Nettoyage</p>
                                </div>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </section>
        </div>
    </div>
{% endblock %}
