<h2 style="color:#16a34a;font-family:Arial,sans-serif;">Nouveau contact du site internet</h2>
<p>{{ contact.createdAt|format_datetime('full', 'short', locale='fr') }}</p>

<p><strong>Type de client :</strong> {{ contact.contactType }}</p>
<p><strong>Délai d'intervention :</strong> {{ contact.interventionDeadline }}</p>
<p><strong>Nom / Prénom :</strong> {{ contact.firstName }} {{ contact.lastName }}</p>
<p><strong>Email :</strong> <a href="mailto:{{ contact.email }}">{{ contact.email }}</a></p>
{% if contact.phoneNumber %}<p><strong>Téléphone :</strong> {{ contact.phoneNumber }}</p>{% endif %}
{% if contact.city or contact.zipCode %}<p><strong>Ville d'intervention :</strong> {{ contact.city }} {{ contact.zipCode }}</p>{% endif %}
{% if contact.message %}<p><strong>Message :</strong><br>{{ contact.message|nl2br }}</p>{% endif %}

<hr>
<small style="color:#6b7280;">Cet email provient du formulaire de contact du site.</small>
