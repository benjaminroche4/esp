{% set _route = app.request.attributes.get('_route') %}
{% set nav_items = [
    { route: 'app_home',                 label: 'Nos prestations' },
    { route: 'app_service_intervention', label: 'Nos interventions' },
    { route: 'app_blog',                 label: 'Blog',              prefix: true }
] %}

{# Wrapper sans positionnement → ne crée pas de stacking context.
   Le <header> et le menu mobile sont siblings : leurs z-index s'appliquent dans le contexte racine. #}
<div data-controller="header">

    <header class="fixed inset-x-0 top-0 z-40 border-b border-gray-200/60 bg-white/85 backdrop-blur-md">
        <nav class="mx-auto flex max-w-7xl items-center justify-between gap-x-4 px-4 py-4 lg:px-8 lg:py-5"
             aria-label="Navigation principale">

            {# Logo #}
            <a href="{{ path('app_home') }}"
               class="flex items-center -m-1.5 p-1.5 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
               aria-label="ESP Débarras et Nettoyage Rhône-Alpes — Accueil">
                <img class="h-7 w-auto sm:h-8"
                     src="{{ asset('medias/logo/esp-debarras-nettoyage-rhone-alpes-logo-header.svg') }}"
                     alt="" width="120" height="32" fetchpriority="high">
                <span class="sr-only">ESP Débarras et Nettoyage Rhône-Alpes</span>
            </a>

            {# Desktop nav #}
            <ul class="flex items-center gap-x-8 text-sm font-medium max-lg:hidden" role="list">
                {% for item in nav_items %}
                    {% set is_current = item.prefix|default(false) ? _route starts with item.route : _route == item.route %}
                    <li>
                        <a href="{{ path(item.route) }}"
                           class="text-gray-700 hover:text-primary aria-[current=page]:text-primary aria-[current=page]:font-semibold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary rounded-sm"
                           {% if is_current %}aria-current="page"{% endif %}>
                            {{ item.label }}
                        </a>
                    </li>
                {% endfor %}
            </ul>

            {# Right side actions #}
            <div class="flex items-center gap-x-3 sm:gap-x-5">

                {# Phone (FR) — visible on mobile and desktop #}
                <a href="tel:+33641288848"
                   class="flex items-center gap-x-2 text-sm font-semibold text-gray-900 hover:text-primary max-[380px]:hidden lg:text-base">
                    <span class="relative flex size-2.5 shrink-0" aria-hidden="true">
                        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex size-2.5 rounded-full bg-green-500"></span>
                    </span>
                    <span class="tabular-nums">06 41 28 88 48</span>
                </a>

                {# Desktop CTA #}
                <a href="{{ path('app_contact') }}"
                   class="rounded-full bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-900 max-lg:hidden">
                    Contactez-nous 7j/7
                </a>

                {# Mobile hamburger #}
                <button type="button"
                        class="relative -m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-700 hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary lg:hidden"
                        data-action="header#open"
                        data-header-target="toggle"
                        aria-controls="header-menu"
                        aria-expanded="false">
                    <span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-1/2 pointer-fine:hidden" aria-hidden="true"></span>
                    <span class="sr-only">Ouvrir le menu</span>
                    <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
                    </svg>
                </button>
            </div>
        </nav>
    </header>

    {# Mobile menu — SIBLING of <header>, NOT inside it.
       Z-50 ici dépasse n'importe quel élément de la page (sections en z-10/20, header en z-40, etc.). #}
    <div id="header-menu"
         class="hidden fixed inset-0 z-50 lg:hidden"
         data-header-target="panel"
         role="dialog"
         aria-modal="true"
         aria-label="Menu de navigation">

        {# Backdrop #}
        <div class="absolute inset-0 bg-gray-900/50 opacity-0 transition-opacity duration-200 ease-out"
             data-header-target="backdrop"
             data-action="click->header#close"
             aria-hidden="true"></div>

        {# Panel — slides in from the right #}
        <div class="absolute inset-y-0 right-0 flex w-full max-w-sm translate-x-full flex-col bg-white shadow-xl transition-transform duration-300 ease-out"
             data-header-target="drawer">
            <div class="flex items-center justify-between gap-x-4 px-6 py-5 border-b border-gray-100">
                <a href="{{ path('app_home') }}" class="flex items-center -m-1.5 p-1.5"
                   aria-label="Accueil">
                    <img class="h-7 w-auto"
                         src="{{ asset('medias/logo/esp-debarras-nettoyage-rhone-alpes-logo-header.svg') }}"
                         alt="" width="120" height="32">
                    <span class="sr-only">ESP Débarras et Nettoyage</span>
                </a>
                <button type="button"
                        class="relative -m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-700 hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                        data-action="header#close"
                        data-header-target="closeButton">
                    <span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-1/2 pointer-fine:hidden" aria-hidden="true"></span>
                    <span class="sr-only">Fermer le menu</span>
                    <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto px-6 py-6">
                <ul class="space-y-1 text-base font-semibold" role="list">
                    {% for item in nav_items %}
                        {% set is_current = item.prefix|default(false) ? _route starts with item.route : _route == item.route %}
                        <li>
                            <a href="{{ path(item.route) }}"
                               class="block rounded-lg px-3 py-3 text-gray-900 hover:bg-gray-50 aria-[current=page]:bg-primary/10 aria-[current=page]:text-primary"
                               data-action="header#close"
                               {% if is_current %}aria-current="page"{% endif %}>
                                {{ item.label }}
                            </a>
                        </li>
                    {% endfor %}
                </ul>

                <div class="mt-8">
                    <a href="{{ path('app_contact') }}"
                       class="block rounded-full bg-gray-900 px-4 py-3 text-center text-base font-semibold text-white hover:bg-gray-700"
                       data-action="header#close">
                        Contactez-nous
                    </a>
                </div>

                <div class="mt-8 rounded-2xl bg-gray-50 p-5 ring-1 ring-gray-200">
                    <p class="text-sm font-semibold text-gray-700">Nous intervenons 7j/7, devis sous 24h&nbsp;:</p>
                    <ul class="mt-3 space-y-2" role="list">
                        <li>
                            <a href="tel:+33641288848" class="flex items-center gap-x-3 text-base font-semibold text-gray-900 hover:text-primary">
                                {{ ux_icon('twemoji:flag-for-flag-france', {class: 'size-5 shrink-0'}) }}
                                <span class="tabular-nums">+33 6 41 28 88 48</span>
                            </a>
                        </li>
                        <li>
                            <a href="tel:+41763044227" class="flex items-center gap-x-3 text-base font-semibold text-gray-900 hover:text-primary">
                                {{ ux_icon('twemoji:flag-for-flag-switzerland', {class: 'size-5 shrink-0'}) }}
                                <span class="tabular-nums">+41 76 304 42 27</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
